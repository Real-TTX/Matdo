@page
@model Matdo.Web.Pages.Projects.ProjectEditModel
@{
    ViewData["Title"] = Model.IsNew ? T["projects.edit.titleNew"] : T["projects.edit.titleEdit"];
    var saved = Request.Query["saved"] == "true";
}
<div class="page-head"><h1>@ViewData["Title"]</h1></div>

@if (saved) { <div class="alert success">@T["projects.edit.saved"]</div> }

<form method="post" class="form-card">
    <input type="hidden" asp-for="Input.Id" />
    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

    <form-field label="@T["common.name"]" for="Input_Name" required="true">
        <input asp-for="Input.Name" placeholder="@T["projects.edit.namePlaceholder"]" autofocus />
        <span asp-validation-for="Input.Name" class="field-error"></span>
    </form-field>

    <form-field label="@T["common.color"]">
        <div class="chip-row">
            @foreach (var c in Matdo.Web.Pages.Projects.ProjectEditModel.Palette)
            {
                var sel = Model.Input.Color == c;
                <label class="chip @(sel ? "active" : "")" title="@c">
                    <input type="radio" name="Input.Color" value="@c" @(sel ? "checked" : "") style="display:none"
                           onchange="document.querySelectorAll('[name=\'Input.Color\']').forEach(r=>r.closest('.chip').classList.toggle('active', r.checked))" />
                    <span class="dot" style="background:@c"></span>
                </label>
            }
        </div>
    </form-field>

    <div class="field-row">
        <form-field label="@T["projects.edit.viewType"]" for="Input_ViewType">
            <select asp-for="Input.ViewType">
                <option value="0">@T["projects.viewType.list"]</option>
                <option value="2">@T["projects.viewType.calendar"]</option>
                <option value="1">@T["projects.viewType.kanban"]</option>
            </select>
        </form-field>
        <form-field label="@T["common.favorite"]">
            <label class="checkbox-row"><input type="checkbox" asp-for="Input.IsFavorite" /> @T["projects.edit.markFavorite"]</label>
        </form-field>
    </div>

    @* Team ergibt sich aus dem Kontext (wo „+" geklickt wurde) und ist nicht wählbar.
       Bei persönlichen Projekten wird gar kein Team-Feld angezeigt. *@
    <input type="hidden" asp-for="Input.TeamId" />
    @{
        var ctxTeam = Model.MyTeams.FirstOrDefault(t => t.Id == Model.Input.TeamId);
    }
    <div class="field-row">
        <form-field label="@T["projects.edit.parent"]">
            <select asp-for="Input.ParentProjectId">
                <option value="">@T["projects.edit.parentNone"]</option>
                @foreach (var pp in Model.ParentOptions)
                {
                    <option value="@pp.Id" selected="@(Model.Input.ParentProjectId == pp.Id)">@pp.Name</option>
                }
            </select>
        </form-field>
        @if (ctxTeam != null)
        {
            <form-field label="@T["projects.edit.team"]">
                <input value="@ctxTeam.Name" readonly />
            </form-field>
        }
    </div>

    <form-buttons>
        <button type="submit" class="btn btn-primary"><icon name="save" size="16" /> @T["common.save"]</button>
        <a class="btn" href="/Projects"><icon name="back" size="16" /> @T["common.back"]</a>
        @if (!Model.IsNew)
        {
            <button type="submit" class="btn danger" asp-page-handler="Delete" asp-route-id="@Model.Input.Id"
                    formnovalidate onclick="return confirm('@T["projects.edit.deleteConfirm"]')"><icon name="trash" size="16" /> @T["common.delete"]</button>
        }
    </form-buttons>
</form>

@if (!Model.IsNew)
{
    <div class="form-card mt" data-tabs-scope>
        <tab-bar>
            <tab-item target="columns" active="true"><icon name="kanban" size="16" /> @T["projects.edit.tabColumns"]</tab-item>
            <tab-item target="pshare"><icon name="share" size="16" /> @T["projects.edit.tabShare"] (@Model.Shares.Count)</tab-item>
        </tab-bar>

        <div class="tab-panel active" data-tab-panel="columns">
            <p class="muted">@T["projects.edit.columnsHint"]</p>
            <div class="table-wrap mb">
                <table class="table">
                    <thead><tr><th>@T["projects.edit.colPosition"]</th><th>@T["common.name"]</th><th></th></tr></thead>
                    <tbody>
                    @foreach (var col in Model.Columns)
                    {
                        <tr>
                            <td>@(col.Position + 1)</td>
                            <td>
                                <form method="post" asp-page-handler="RenameColumn" asp-route-id="@Model.Input.Id" style="display:flex; gap:6px">
                                    <input type="hidden" name="columnId" value="@col.Id" />
                                    <input type="text" name="columnName" value="@col.Name" />
                                    <button type="submit" class="btn small">OK</button>
                                </form>
                            </td>
                            <td class="actions-cell">
                                <form method="post" asp-page-handler="DeleteColumn" asp-route-id="@Model.Input.Id" style="display:inline" data-confirm="@T["projects.edit.deleteColumnConfirm"]">
                                    <input type="hidden" name="columnId" value="@col.Id" />
                                    <button type="submit" class="btn small danger"><icon name="trash" size="14" /></button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (Model.Columns.Count == 0)
                    {
                        <tr><td colspan="3"><div class="empty">@T["projects.edit.noColumns"]</div></td></tr>
                    }
                    </tbody>
                </table>
            </div>
            <form method="post" asp-page-handler="AddColumn" asp-route-id="@Model.Input.Id" style="display:flex; gap:6px; max-width:360px">
                <input type="text" name="columnName" placeholder="@T["projects.edit.newColumnPlaceholder"]" required />
                <button type="submit" class="btn btn-primary"><icon name="plus" size="16" /> @T["common.add"]</button>
            </form>
        </div>

        <div class="tab-panel" data-tab-panel="pshare">
            @if (!string.IsNullOrEmpty(Model.ShareMessage))
            {
                <div class="alert info">@Model.ShareMessage</div>
            }

            @* Freigabe per E-Mail-Adresse (auch an noch nicht registrierte Personen). *@
            <form method="post" asp-page-handler="ShareByEmail" asp-route-id="@Model.Input.Id" class="mb">
                <div class="field-row">
                    <form-field label="@T["projects.edit.shareByEmail"]">
                        <input type="email" name="shareEmail" placeholder="du@beispiel.de" />
                    </form-field>
                    <form-field label="@T["projects.edit.sharePermission"]">
                        <select name="shareEmailPermission">
                            <option value="1">@T["projects.edit.permEdit"]</option>
                            <option value="0">@T["projects.edit.permView"]</option>
                        </select>
                    </form-field>
                </div>
                <div class="form-buttons" style="margin-top:6px">
                    <button type="submit" class="btn btn-primary small"><icon name="share" size="14" /> @T["projects.edit.inviteByEmail"]</button>
                </div>
            </form>

            @if (Model.PendingInvites.Count > 0)
            {
                <h4 class="mt">@T["projects.edit.pendingInvites"]</h4>
                <div class="table-wrap mb">
                    <table class="table">
                        <tbody>
                        @foreach (var inv in Model.PendingInvites)
                        {
                            <tr>
                                <td>@inv.Email <span class="badge">@T["projects.edit.pending"]</span></td>
                                <td class="actions-cell">
                                    <form method="post" asp-page-handler="CancelInvite" asp-route-id="@Model.Input.Id" style="display:inline">
                                        <input type="hidden" name="invitationId" value="@inv.Id" />
                                        <button type="submit" class="btn small danger"><icon name="x" size="14" /></button>
                                    </form>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }

            @if (Model.Shares.Count > 0)
            {
                <div class="table-wrap mb">
                    <table class="table">
                        <thead><tr><th>@T["projects.edit.shareUser"]</th><th>@T["projects.edit.sharePermission"]</th><th></th></tr></thead>
                        <tbody>
                        @foreach (var s in Model.Shares)
                        {
                            <tr>
                                <td>@s.SharedWithUser?.DisplayName</td>
                                <td>@(s.Permission == Matdo.Web.Data.Entities.SharePermission.Edit ? T["projects.edit.permEdit"] : T["projects.edit.permView"])</td>
                                <td class="actions-cell">
                                    <form method="post" asp-page-handler="Unshare" asp-route-id="@Model.Input.Id" style="display:inline">
                                        <input type="hidden" name="targetUserId" value="@s.SharedWithUserId" />
                                        <button type="submit" class="btn small danger"><icon name="x" size="14" /></button>
                                    </form>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
            @if (Model.ShareableUsers.Count == 0)
            {
                <p class="muted">@T["projects.edit.noShareableUsers"]</p>
            }
            else
            {
                <form method="post" asp-page-handler="Share" asp-route-id="@Model.Input.Id">
                    <div class="field-row">
                        <form-field label="@T["projects.edit.shareUser"]">
                            <select name="targetUserId">
                                @foreach (var u in Model.ShareableUsers)
                                {
                                    <option value="@u.Id">@u.DisplayName</option>
                                }
                            </select>
                        </form-field>
                        <form-field label="@T["projects.edit.sharePermission"]">
                            <select name="permission">
                                <option value="1">@T["projects.edit.permEdit"]</option>
                                <option value="0">@T["projects.edit.permView"]</option>
                            </select>
                        </form-field>
                    </div>
                    <div class="form-buttons" style="margin-top:6px">
                        <button type="submit" class="btn btn-primary small"><icon name="share" size="14" /> @T["projects.edit.share"]</button>
                    </div>
                </form>
            }
        </div>
    </div>

    <div class="form-card mt" id="feed">
        <h3><icon name="calendar" size="16" /> @T["projects.edit.feedTitle"]</h3>
        <p class="hint muted">@T["projects.edit.feedHint"]</p>
        @if (Model.IcalFeedUrl != null)
        {
            <form-field><input type="text" value="@Model.IcalFeedUrl" readonly onclick="this.select()" /></form-field>
        }
        <div class="form-buttons">
            <form method="post" asp-page-handler="Feed" asp-route-id="@Model.Input.Id" style="display:inline">
                <button type="submit" class="btn small"><icon name="calendar" size="14" /> @(Model.IcalFeedUrl == null ? T["projects.edit.feedGenerate"] : T["projects.edit.feedRegenerate"])</button>
            </form>
            @if (Model.IcalFeedUrl != null)
            {
                <form method="post" asp-page-handler="FeedDisable" asp-route-id="@Model.Input.Id" style="display:inline" data-confirm="@T["calendar.feedDisableConfirm"]">
                    <button type="submit" class="btn small danger"><icon name="x" size="14" /> @T["settings.disable"]</button>
                </form>
            }
        </div>
    </div>

    <div class="form-card mt">
        <h3><icon name="share" size="16" /> @T["projects.edit.anonTitle"]</h3>
        <p class="hint muted">@T["projects.edit.anonHint"]</p>
        @if (Model.AnonUrl != null)
        {
            <form-field><input type="text" value="@Model.AnonUrl" readonly onclick="this.select()" /></form-field>
        }
        <div class="form-buttons">
            <form method="post" asp-page-handler="Anon" asp-route-id="@Model.Input.Id" style="display:inline">
                <button type="submit" class="btn small"><icon name="share" size="14" /> @(Model.AnonUrl == null ? T["projects.edit.anonGenerate"] : T["projects.edit.feedRegenerate"])</button>
            </form>
            @if (Model.AnonUrl != null)
            {
                <form method="post" asp-page-handler="AnonDisable" asp-route-id="@Model.Input.Id" style="display:inline" data-confirm="@T["projects.edit.anonDisableConfirm"]">
                    <button type="submit" class="btn small danger"><icon name="x" size="14" /> @T["settings.disable"]</button>
                </form>
            }
        </div>
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
