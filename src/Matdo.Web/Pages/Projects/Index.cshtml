@page
@model Matdo.Web.Pages.Projects.ProjectsIndexModel
@{
    ViewData["Title"] = "Projekte";
}
<div class="page-head"><h1>Meine Projekte</h1></div>

<list-view id="projects">
    <!-- Toolbar: Suche + Sortierung (immer über der Liste) -->
    <list-toolbar>
        <form method="get" class="search">
            <input type="search" name="q" value="@Model.Search" placeholder="Projekte durchsuchen …" />
        </form>
        <div class="grow"></div>
        <form method="get" id="sortForm">
            <input type="hidden" name="q" value="@Model.Search" />
            <select name="sort" onchange="document.getElementById('sortForm').submit()">
                <option value="name" selected="@(Model.Sort == "name")">Name (A–Z)</option>
                <option value="name_desc" selected="@(Model.Sort == "name_desc")">Name (Z–A)</option>
                <option value="view" selected="@(Model.Sort == "view")">Ansicht</option>
            </select>
        </form>
    </list-toolbar>

    <list-table>
        <thead>
            <tr>
                <th>Name</th>
                <th>Ansicht</th>
                <th>Offen</th>
                <th>Favorit</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var row in Model.Rows)
        {
            <tr>
                <td>
                    <a class="row-link" href="/Projects/View?id=@row.Project.Id">
                        <span class="dot" style="background:@row.Project.Color; display:inline-block; margin-right:6px"></span>@row.Project.Name
                    </a>
                </td>
                <td>@(row.Project.ViewType == ProjectViewType.Kanban ? "Board" : "Liste")</td>
                <td>@row.OpenTasks</td>
                <td>@(row.Project.IsFavorite ? "★" : "")</td>
                <td class="actions-cell">
                    <a class="btn small" href="/Projects/Edit?id=@row.Project.Id"><icon name="edit" size="14" /> Bearbeiten</a>
                </td>
            </tr>
        }
        @if (Model.Rows.Count == 0)
        {
            <tr><td colspan="5"><div class="empty">Noch keine Projekte.</div></td></tr>
        }
        </tbody>
    </list-table>

    <!-- Listen-Aktionen: links bündig, unterhalb der Tabelle -->
    <list-actions>
        <a class="btn btn-primary" href="/Projects/Edit"><icon name="plus" size="16" /> Neues Projekt</a>
    </list-actions>
</list-view>
