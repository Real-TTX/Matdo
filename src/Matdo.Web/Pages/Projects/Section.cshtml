@page
@model Matdo.Web.Pages.Projects.SectionModel
@{
    ViewData["Title"] = T["projects.section.edit"];
    if (Request.Query.ContainsKey("modal")) { Layout = null; }
    var cid = Model.Column.Id;
    var pid = Model.ProjectId;
}
<div class="page-head"><h1>@T["projects.section.edit"]</h1></div>

<form method="post" asp-page-handler="Rename" class="form-card" data-modal-reload>
    <input type="hidden" name="id" value="@cid" />
    <input type="hidden" name="pid" value="@pid" />

    <form-field label="@T["common.name"]" for="name" required="true">
        <input name="name" type="text" value="@Model.Column.Name" required autofocus />
    </form-field>

    @if (Model.MoveTargets.Count > 0)
    {
        <form-field label="@T["projects.section.moveTo"]" for="targetProjectId">
            <select name="targetProjectId">
                @foreach (var mt in Model.MoveTargets)
                {
                    <option value="@mt.Id">@mt.Name</option>
                }
            </select>
        </form-field>
    }

    @* Sekundäraktionen (formnovalidate, damit das Pflicht-Namensfeld sie nicht blockiert). *@
    <div class="form-buttons" style="flex-wrap:wrap">
        <button type="submit" class="btn small" asp-page-handler="Duplicate" formnovalidate><icon name="copy" size="14" /> @T["projects.menu.duplicate"]</button>
        @if (Model.MoveTargets.Count > 0)
        {
            <button type="submit" class="btn small" asp-page-handler="Move" formnovalidate><icon name="chevron-right" size="14" /> @T["projects.section.moveTo"]</button>
        }
        <button type="submit" class="btn small danger" asp-page-handler="Delete" formnovalidate onclick="return confirm('@T["projects.edit.deleteColumnConfirm"]')"><icon name="trash" size="14" /> @T["common.delete"]</button>
    </div>

    <div class="menu-sep"></div>

    @* Primär: Speichern / Abbrechen immer ganz unten. *@
    <form-buttons>
        <button type="submit" class="btn btn-primary"><icon name="save" size="16" /> @T["common.save"]</button>
        <a class="btn" href="/Projects/View?id=@pid" data-modal-close><icon name="back" size="16" /> @T["common.cancel"]</a>
    </form-buttons>
</form>
