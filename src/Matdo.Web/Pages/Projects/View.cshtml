@page
@model Matdo.Web.Pages.Projects.ProjectViewModel
@{
    ViewData["Title"] = "#" + Model.Project.Name;
    var pid = Model.Project.Id;
    ViewData["Crumbs"] = new List<Matdo.Web.ViewModels.Crumb>
    {
        new(T["nav.myProjects"], "/Projects"),
        new("#" + Model.Project.Name)
    };
    var noColumn = Model.Tasks.Where(t => t.KanbanColumnId == null).ToList();
    var composer = new ComposerOptions { ReturnUrl = $"/Projects/View?id={Model.Project.Id}", DefaultProjectId = Model.Project.Id };
    var cal = new Matdo.Web.ViewModels.CalendarMonth
    {
        Year = Model.CalYear,
        Month = Model.CalMonth,
        Tasks = Model.Tasks,
        NavUrlTemplate = $"/Projects/View?id={pid}&view=calendar&ym={{ym}}",
        AddUrlTemplate = $"/Tasks/Edit?projectId={pid}&due={{date}}"
    };
}
@section TopbarActions {
    <div class="tb-menu" data-menu>
        <button type="button" class="icon-btn" data-menu-toggle aria-label="@T["projects.view.settings"]"><icon name="dots" /></button>
        <div class="menu-pop">
            <a class="menu-item" href="/Projects/Edit?id=@pid"><icon name="settings" size="15" /> @T["projects.view.settings"]</a>
            <a class="menu-item" href="/projects/@pid/export.csv"><icon name="upload" size="15" /> @T["projects.menu.exportCsv"]</a>
            <a class="menu-item" href="/Account/Settings?tab=import"><icon name="inbox" size="15" /> @T["projects.menu.importCsv"]</a>
            <a class="menu-item" href="/Projects/Edit?id=@pid#feed"><icon name="calendar" size="15" /> @T["projects.edit.feedTitle"]</a>
            <div class="menu-sep"></div>
            <form method="post" asp-page="/Projects/Edit" asp-page-handler="Delete" asp-route-id="@pid" data-confirm="@T["projects.edit.deleteConfirm"]">
                <button type="submit" class="menu-item danger"><icon name="trash" size="15" /> @T["common.delete"]</button>
            </form>
        </div>
    </div>
}
<div class="page-head">
    <h1><span class="phash" style="color:@Model.Project.Color; margin-right:2px">#</span>@Model.Project.Name</h1>
    <div class="sub">@Model.Tasks.Count @T["projects.view.openTasks"]</div>
</div>

@* Der Ansichtstyp (Liste/Kalender/Board) wird ausschließlich in den Projekteinstellungen
   festgelegt – hier wird das Projekt in seinem konfigurierten Typ dargestellt. *@
@if (Model.ViewMode == "list")
{
    <partial name="_Composer" model="composer" />

    @foreach (var t in Model.Tasks)
    {
        <partial name="_TaskRow" model="t" />
    }
    @if (Model.Tasks.Count == 0)
    {
        <div class="empty">@T["projects.view.noOpenTasks"]</div>
    }
}
else if (Model.ViewMode == "calendar")
{
    <partial name="_Calendar" model="cal" />
}
else
{
    <div class="kanban">
        @foreach (var col in Model.Columns)
        {
            var colTasks = Model.Tasks.Where(t => t.KanbanColumnId == col.Id).OrderBy(t => t.Position).ToList();
            <div class="kanban-col">
                <h4>@col.Name <span class="col-count">@colTasks.Count</span></h4>
                <div class="kanban-cards" data-column-id="@col.Id">
                    @foreach (var t in colTasks)
                    {
                        <partial name="_KanbanCard" model="t" />
                    }
                </div>
            </div>
        }

        @if (noColumn.Count > 0)
        {
            <div class="kanban-col">
                <h4>@T["projects.view.noColumn"] <span class="col-count">@noColumn.Count</span></h4>
                <div class="kanban-cards" data-column-id="">
                    @foreach (var t in noColumn)
                    {
                        <partial name="_KanbanCard" model="t" />
                    }
                </div>
            </div>
        }

        @if (Model.Columns.Count == 0)
        {
            <div class="add-col">
                <div class="empty">@T["projects.view.noColumnsYet"] <a href="/Projects/Edit?id=@pid">@T["projects.view.defineColumns"]</a></div>
            </div>
        }
    </div>
    <a class="btn small" href="/Tasks/Edit?projectId=@pid"><icon name="plus" size="14" /> @T["projects.view.addTask"]</a>
}
