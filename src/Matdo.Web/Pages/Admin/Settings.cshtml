@page
@model Matdo.Web.Pages.Admin.AdminSettingsModel
@{
    ViewData["Title"] = T["admin.settings.title"];
}
<div class="page-head"><h1>@T["admin.settings.title"]</h1></div>

@if (!string.IsNullOrEmpty(Model.Message)) { <div class="alert success">@Model.Message</div> }
<p class="muted mb">@T["admin.settings.storageHint"]</p>

<form method="post" class="form-card" style="max-width:none">
    <div data-tabs-scope>
        <tab-bar>
            <tab-item target="general" active="true"><icon name="settings" size="16" /> @T["admin.settings.tab.general"]</tab-item>
            <tab-item target="smtp"><icon name="bell" size="16" /> @T["admin.settings.tab.smtp"]</tab-item>
            <tab-item target="push"><icon name="bell" size="16" /> @T["admin.settings.tab.push"]</tab-item>
            <tab-item target="cal"><icon name="calendar" size="16" /> @T["admin.settings.tab.calendar"]</tab-item>
        </tab-bar>

        <div class="tab-panel active" data-tab-panel="general">
            <div class="field-row">
                <form-field label="@T["admin.settings.appName"]"><input asp-for="Config.AppName" /></form-field>
                <form-field label="@T["admin.settings.publicBaseUrl"]" hint="@T["admin.settings.publicBaseUrl.hint"]"><input asp-for="Config.PublicBaseUrl" /></form-field>
            </div>
            <form-field label="@T["admin.settings.allowRegistration"]" hint="@T["admin.settings.allowRegistration.hint"]">
                <label class="checkbox-row"><input type="checkbox" asp-for="Config.AllowRegistration" /> @T["admin.settings.allowRegistration.label"]</label>
            </form-field>
        </div>

        <div class="tab-panel" data-tab-panel="smtp">
            <form-field label="@T["admin.settings.smtpEnabled"]">
                <label class="checkbox-row"><input type="checkbox" asp-for="Config.Smtp.Enabled" /> @T["admin.settings.smtpEnabled.label"]</label>
            </form-field>
            <div class="field-row">
                <form-field label="@T["admin.settings.smtp.host"]"><input asp-for="Config.Smtp.Host" placeholder="smtp.example.com" /></form-field>
                <form-field label="@T["admin.settings.smtp.port"]"><input asp-for="Config.Smtp.Port" type="number" /></form-field>
            </div>
            <form-field label="@T["admin.settings.smtp.startTls"]">
                <label class="checkbox-row"><input type="checkbox" asp-for="Config.Smtp.UseStartTls" /> @T["admin.settings.smtp.startTls.label"]</label>
            </form-field>
            <div class="field-row">
                <form-field label="@T["admin.settings.smtp.user"]"><input asp-for="Config.Smtp.User" autocomplete="off" /></form-field>
                <form-field label="@T["admin.settings.smtp.password"]"><input asp-for="Config.Smtp.Password" type="password" autocomplete="new-password" /></form-field>
            </div>
            <div class="field-row">
                <form-field label="@T["admin.settings.smtp.fromAddress"]"><input asp-for="Config.Smtp.FromAddress" /></form-field>
                <form-field label="@T["admin.settings.smtp.fromName"]"><input asp-for="Config.Smtp.FromName" /></form-field>
            </div>
        </div>

        <div class="tab-panel" data-tab-panel="push">
            <form-field label="@T["admin.settings.pushEnabled"]">
                <label class="checkbox-row"><input type="checkbox" asp-for="Config.Push.Enabled" /> @T["admin.settings.pushEnabled.label"]</label>
            </form-field>
            <form-field label="@T["admin.settings.push.subject"]" hint="@T["admin.settings.push.subject.hint"]">
                <input asp-for="Config.Push.Subject" />
            </form-field>
            <form-field label="@T["admin.settings.push.publicKey"]"><input asp-for="Config.Push.PublicKey" readonly /></form-field>
            <form-field label="@T["admin.settings.push.privateKey"]"><input asp-for="Config.Push.PrivateKey" type="password" readonly /></form-field>
            <button type="submit" class="btn small" asp-page-handler="GenerateVapid"><icon name="settings" size="14" /> @T["admin.settings.push.generateVapid"]</button>
        </div>

        <div class="tab-panel" data-tab-panel="cal">
            @{ var baseUrl = (Model.Config.PublicBaseUrl ?? "").TrimEnd('/'); }
            <h3>Google</h3>
            <form-field label="@T["admin.settings.cal.enabled"]">
                <label class="checkbox-row"><input type="checkbox" asp-for="Config.Google.Enabled" /> @T["admin.settings.cal.enableLabel"]</label>
            </form-field>
            <div class="field-row">
                <form-field label="@T["admin.settings.cal.clientId"]"><input asp-for="Config.Google.ClientId" autocomplete="off" /></form-field>
                <form-field label="@T["admin.settings.cal.clientSecret"]"><input asp-for="Config.Google.ClientSecret" type="password" autocomplete="new-password" /></form-field>
            </div>
            <div class="hint muted">@T["admin.settings.cal.redirectHint"] <code>@baseUrl/calendar/callback/google</code></div>
            <div class="hint mb"><a href="/Admin/CalendarGuide#google" target="_blank" rel="noopener">📖 @T["admin.settings.cal.guideLink"]</a></div>

            <h3 class="mt">Microsoft</h3>
            <form-field label="@T["admin.settings.cal.enabled"]">
                <label class="checkbox-row"><input type="checkbox" asp-for="Config.Microsoft.Enabled" /> @T["admin.settings.cal.enableLabel"]</label>
            </form-field>
            <div class="field-row">
                <form-field label="@T["admin.settings.cal.clientId"]"><input asp-for="Config.Microsoft.ClientId" autocomplete="off" /></form-field>
                <form-field label="@T["admin.settings.cal.clientSecret"]"><input asp-for="Config.Microsoft.ClientSecret" type="password" autocomplete="new-password" /></form-field>
            </div>
            <div class="hint muted">@T["admin.settings.cal.redirectHint"] <code>@baseUrl/calendar/callback/microsoft</code></div>
            <div class="hint"><a href="/Admin/CalendarGuide#microsoft" target="_blank" rel="noopener">📖 @T["admin.settings.cal.guideLinkMs"]</a></div>
        </div>
    </div>

    <form-buttons>
        <button type="submit" class="btn btn-primary"><icon name="save" size="16" /> @T["common.save"]</button>
        <a class="btn" href="/Admin"><icon name="back" size="16" /> @T["common.back"]</a>
    </form-buttons>
</form>
