@page
@model Matdo.Web.Pages.Admin.AdminIndexModel
@{
    ViewData["Title"] = T["admin.index.title"];
}
<div class="page-head"><h1>@T["admin.index.title"]</h1></div>

<div class="cards">
    <a class="stat-card" href="/Admin/Users"><div class="n">@Model.Users</div><div class="l"><icon name="users" size="14" /> @T["admin.index.users"]</div></a>
    <a class="stat-card" href="/Admin/Groups"><div class="n">@Model.Groups</div><div class="l"><icon name="group" size="14" /> @T["admin.index.groups"]</div></a>
    <a class="stat-card" href="/Admin/Teams"><div class="n">@Model.Teams</div><div class="l"><icon name="users" size="14" /> @T["admin.teams.title"]</div></a>
    <a class="stat-card" href="/Admin/Roles"><div class="n">@Model.Roles</div><div class="l"><icon name="settings" size="14" /> @T["admin.index.roles"]</div></a>
    <div class="stat-card"><div class="n">@Model.Projects</div><div class="l">@T["admin.index.projects"]</div></div>
    <div class="stat-card"><div class="n">@Model.Tasks</div><div class="l">@T["admin.index.tasks"]</div></div>
    <div class="stat-card"><div class="n">@Model.Sessions</div><div class="l">@T["admin.index.activeSessions"]</div></div>
</div>

<div class="list-actions">
    <a class="btn" href="/Admin/Users"><icon name="users" size="16" /> @T["admin.index.userManagement"]</a>
    <a class="btn" href="/Admin/Groups"><icon name="group" size="16" /> @T["admin.index.groups"]</a>
    <a class="btn" href="/Admin/Teams"><icon name="users" size="16" /> @T["admin.teams.title"]</a>
    <a class="btn" href="/Admin/Roles"><icon name="settings" size="16" /> @T["admin.index.roles"]</a>
    <a class="btn" href="/Admin/Settings"><icon name="bell" size="16" /> @T["admin.index.systemSettings"]</a>
</div>
