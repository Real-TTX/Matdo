@page
@model Matdo.Web.Pages.SearchModel
@{
    ViewData["Title"] = T["search.title"];
}
<div class="page-head"><h1>@T["search.title"]</h1></div>

<list-view id="search">
    <list-toolbar>
        <form method="get" id="searchForm" class="search" style="max-width:none; flex:1; display:flex; gap:8px">
            <input type="search" name="q" value="@Model.Query" placeholder="@T["search.placeholder"]" autofocus />
            <button type="submit" class="btn btn-primary"><icon name="search" size="16" /> @T["common.search"]</button>
        </form>
    </list-toolbar>
</list-view>

@if (!string.IsNullOrWhiteSpace(Model.Query))
{
    <div class="sub muted mb">@Model.Results.Count @T["search.resultsFor"] „@Model.Query"</div>
    @foreach (var t in Model.Results)
    {
        <partial name="_TaskRow" model="t" />
    }
    @if (Model.Results.Count == 0)
    {
        <div class="empty">@T["search.noResults"]</div>
    }
}
