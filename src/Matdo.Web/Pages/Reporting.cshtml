@page
@model Matdo.Web.Pages.ReportingModel
@{
    ViewData["Title"] = "Reporting";
    var maxDay = Math.Max(1, Model.Last7Days.DefaultIfEmpty(0).Max());
    var maxProj = Math.Max(1, Model.ByProject.Select(p => p.Count).DefaultIfEmpty(0).Max());
}
<div class="page-head"><h1>Reporting</h1></div>

<div class="cards">
    <div class="stat-card"><div class="n">@Model.Open</div><div class="l">Offene Aufgaben</div></div>
    <div class="stat-card"><div class="n" style="color:var(--green)">@Model.CompletedLast7</div><div class="l">Erledigt (7 Tage)</div></div>
    <div class="stat-card"><div class="n">@Model.CompletedTotal</div><div class="l">Erledigt gesamt</div></div>
    <div class="stat-card"><div class="n" style="color:var(--danger)">@Model.Overdue</div><div class="l">Überfällig</div></div>
</div>

<div class="form-card" style="max-width:none">
    <h3>Erledigt in den letzten 7 Tagen</h3>
    <div style="display:flex; align-items:flex-end; gap:10px; height:160px; padding:12px 0; border-bottom:1px solid var(--border)">
        @for (var i = 0; i < 7; i++)
        {
            var h = (int)(Model.Last7Days[i] / (double)maxDay * 130);
            <div style="flex:1; display:flex; flex-direction:column; align-items:center; gap:6px; justify-content:flex-end">
                <div style="font-size:12px; color:var(--text-muted)">@Model.Last7Days[i]</div>
                <div style="width:100%; max-width:42px; height:@(h)px; background:var(--accent); border-radius:6px 6px 0 0"></div>
                <div style="font-size:12px; color:var(--text-muted)">@Model.Last7Labels[i]</div>
            </div>
        }
    </div>
</div>

<div class="form-card mt" style="max-width:none">
    <h3>Offene Aufgaben je Projekt</h3>
    @if (Model.ByProject.Count == 0)
    {
        <div class="empty">Keine Daten.</div>
    }
    else
    {
        foreach (var p in Model.ByProject)
        {
            var w = (int)(p.Count / (double)maxProj * 100);
            <div style="margin:8px 0">
                <div class="row-between" style="font-size:13px"><span><span class="dot" style="background:@p.Color; display:inline-block; margin-right:6px"></span>@p.Name</span><strong>@p.Count</strong></div>
                <div style="height:8px; background:var(--hover); border-radius:6px; overflow:hidden; margin-top:3px"><div style="width:@(w)%; height:100%; background:@p.Color"></div></div>
            </div>
        }
    }
</div>
