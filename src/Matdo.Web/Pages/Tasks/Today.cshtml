@page
@model Matdo.Web.Pages.Tasks.TodayModel
@{
    ViewData["Title"] = T["tasks.today.title"];
    var total = Model.Overdue.Count + Model.DueToday.Count;
    var composer = new ComposerOptions { ReturnUrl = "/Tasks/Today", DefaultDueToday = true };
}
<div class="page-head">
    <h1>@T["tasks.today.title"]</h1>
    <div class="sub"><icon name="check" size="16" /> @total @T["tasks.common.tasks"]</div>
</div>

@if (Model.Overdue.Count > 0)
{
    <div class="task-group">
        <h3><span class="overdue-head">@T["tasks.today.overdue"]</span></h3>
        @foreach (var t in Model.Overdue)
        {
            <partial name="_TaskRow" model="t" />
        }
    </div>
}

@if (Model.Events.Count > 0)
{
    <div class="task-group">
        <h3>@T["calendar.events"]</h3>
        @foreach (var e in Model.Events)
        {
            <div class="task-row">
                <div class="task-body">
                    <div class="task-title">
                        <span class="dot" style="background:@e.Color; display:inline-block; margin-right:6px"></span>
                        @if (!e.AllDay) { <span class="muted">@e.StartUtc.ToLocalTime().ToString("HH:mm")</span> }
                        @e.Title
                    </div>
                </div>
            </div>
        }
    </div>
}

<div class="task-group">
    <h3>@DateTime.Now.ToString("d. MMM") · @T["tasks.common.today"] · @DateTime.Now.ToString("dddd")</h3>

    <partial name="_Composer" model="composer" />

    @foreach (var t in Model.DueToday)
    {
        <partial name="_TaskRow" model="t" />
    }
    @if (total == 0)
    {
        <div class="empty">@T["tasks.today.empty"]</div>
    }
</div>
