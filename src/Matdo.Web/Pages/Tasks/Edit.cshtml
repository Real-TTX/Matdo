@page
@model Matdo.Web.Pages.Tasks.TaskEditModel
@{
    ViewData["Title"] = Model.IsNew ? T["tasks.edit.titleNew"] : T["tasks.edit.titleEdit"];
    var saved = Request.Query["saved"] == "true";
    var prios = new[] { (1, T["tasks.priority.p1"]), (2, T["tasks.priority.p2"]), (3, T["tasks.priority.p3"]), (4, T["tasks.priority.p4"]) };
    // Im Dialog-Modus ohne App-Layout rendern (nur der Formularinhalt wird per fetch geladen).
    if (Request.Query.ContainsKey("modal")) { Layout = null; }
    var projectPicker = new Matdo.Web.ViewModels.ProjectPickerOptions { FieldName = "Input.ProjectId", SelectedId = Model.Input.ProjectId };
}
<div class="page-head">
    <h1>@ViewData["Title"]</h1>
</div>

@if (saved) { <div class="alert success">@T["tasks.edit.saved"]</div> }

<form method="post" class="form-card">
    <input type="hidden" asp-for="Input.Id" />
    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

    <form-field label="@T["tasks.edit.titleLabel"]" for="Input_Title" required="true">
        <input asp-for="Input.Title" placeholder="@T["tasks.edit.titlePlaceholder"]" data-smart="1" autofocus />
        <span asp-validation-for="Input.Title" class="field-error"></span>
    </form-field>

    <form-field label="@T["common.description"]" for="Input_Description">
        <textarea asp-for="Input.Description" placeholder="@T["tasks.edit.descriptionPlaceholder"]"></textarea>
    </form-field>

    <div class="field-row">
        <form-field label="@T["tasks.edit.project"]">
            <partial name="_ProjectPicker" model="projectPicker" />
        </form-field>
        <form-field label="@T["tasks.edit.priority"]" for="Input_Priority">
            <select asp-for="Input.Priority">
                @foreach (var (val, text) in prios)
                {
                    <option value="@val">@text</option>
                }
            </select>
        </form-field>
    </div>

    @if (Model.TeamMembers.Count > 0)
    {
        <form-field label="@T["tasks.edit.assignee"]" for="Input_AssigneeId">
            <select asp-for="Input.AssigneeId">
                <option value="">@T["tasks.edit.assigneeNone"]</option>
                @foreach (var u in Model.TeamMembers)
                {
                    <option value="@u.Id" selected="@(Model.Input.AssigneeId == u.Id)">@u.DisplayName</option>
                }
            </select>
        </form-field>
    }
    else
    {
        <input type="hidden" asp-for="Input.AssigneeId" />
    }

    <div class="field-row">
        <form-field label="@T["tasks.edit.due"]" for="Input_DueDate">
            <input asp-for="Input.DueDate" type="date" />
        </form-field>
        <form-field label="@T["tasks.edit.time"]" for="Input_DueTime" hint="@T["common.optional"]">
            <input asp-for="Input.DueTime" type="time" />
        </form-field>
    </div>

    <div class="field-row">
        <form-field label="@T["tasks.edit.deadline"]" for="Input_DeadlineDate">
            <input asp-for="Input.DeadlineDate" type="date" />
        </form-field>
        <form-field label="@T["tasks.edit.time"]" for="Input_DeadlineTime" hint="@T["common.optional"]">
            <input asp-for="Input.DeadlineTime" type="time" />
        </form-field>
    </div>

    <form-field label="@T["tasks.edit.labels"]">
        @if (Model.AllLabels.Count == 0)
        {
            <div class="muted">@T["tasks.edit.noLabels"] <a href="/Labels/Edit">@T["tasks.edit.createLabel"]</a></div>
        }
        else
        {
            <div class="chip-row">
                @foreach (var l in Model.AllLabels)
                {
                    var check = Model.Input.LabelIds.Contains(l.Id);
                    <label class="chip @(check ? "active" : "")">
                        <input type="checkbox" name="Input.LabelIds" value="@l.Id" @(check ? "checked" : "") style="display:none" onchange="this.closest('.chip').classList.toggle('active', this.checked)" />
                        <span class="tag-swatch" style="background:@l.Color"></span> @l.Name
                    </label>
                }
            </div>
        }
    </form-field>

    <!-- Buttons in einer Zeile: Speichern, Zurück, <Abstand> Löschen -->
    <form-buttons>
        <button type="submit" class="btn btn-primary"><icon name="save" size="16" /> @T["common.save"]</button>
        <a class="btn" href="javascript:history.back()" data-modal-close><icon name="back" size="16" /> @T["common.back"]</a>
        @if (!Model.IsNew)
        {
            <button type="submit" class="btn danger" asp-page-handler="Delete" asp-route-id="@Model.Input.Id"
                    formnovalidate onclick="return confirm('@T["tasks.edit.deleteConfirm"]')"><icon name="trash" size="16" /> @T["common.delete"]</button>
        }
    </form-buttons>
</form>

@if (!Model.IsNew)
{
    <div class="form-card mt" data-tabs-scope>
        <tab-bar>
            <tab-item target="subtasks" active="true"><icon name="list" size="16" /> @T["tasks.edit.subtasks"] (@Model.SubTasks.Count)</tab-item>
            <tab-item target="reminders"><icon name="bell" size="16" /> @T["tasks.edit.reminders"] (@Model.Reminders.Count)</tab-item>
            @if (Model.CanShare)
            {
                <tab-item target="share"><icon name="share" size="16" /> @T["tasks.edit.share"] (@Model.Shares.Count)</tab-item>
            }
        </tab-bar>

        <!-- Unteraufgaben -->
        <div class="tab-panel active" data-tab-panel="subtasks">
            @foreach (var s in Model.SubTasks)
            {
                <partial name="_TaskRow" model="s" />
            }
            <form method="post" asp-page-handler="AddSubtask" asp-route-id="@Model.Input.Id" class="composer">
                <input class="title" name="subtaskTitle" placeholder="@T["tasks.edit.addStepPlaceholder"]" autocomplete="off" required />
                <div class="form-buttons" style="margin-top:6px">
                    <button type="submit" class="btn btn-primary small"><icon name="plus" size="14" /> @T["tasks.edit.addStep"]</button>
                </div>
            </form>
        </div>

        <!-- Erinnerungen -->
        <div class="tab-panel" data-tab-panel="reminders">
            @if (Model.Reminders.Count == 0)
            {
                <p class="muted">@T["tasks.edit.noReminders"]</p>
            }
            else
            {
                <div class="table-wrap mb">
                    <table class="table">
                        <thead><tr><th>@T["tasks.edit.reminderTime"]</th><th>@T["tasks.edit.reminderType"]</th><th>@T["tasks.edit.reminderChannel"]</th><th></th></tr></thead>
                        <tbody>
                        @foreach (var r in Model.Reminders)
                        {
                            <tr>
                                <td>@r.RemindAt.ToLocalTime().ToString("g")</td>
                                <td>@(r.Type == Matdo.Web.Data.Entities.ReminderType.DateTime ? T["tasks.edit.reminderDateTime"] : $"{r.OffsetMinutes} {T["tasks.edit.reminderMinutesBefore"]}")</td>
                                <td>@r.Channel</td>
                                <td class="actions-cell">
                                    <form method="post" asp-page-handler="RemoveReminder" asp-route-id="@Model.Input.Id" style="display:inline">
                                        <input type="hidden" name="reminderId" value="@r.Id" />
                                        <button type="submit" class="btn small danger"><icon name="trash" size="14" /></button>
                                    </form>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }

            <form method="post" asp-page-handler="AddReminder" asp-route-id="@Model.Input.Id">
                <div class="field-row">
                    <form-field label="@T["tasks.edit.reminderKind"]">
                        <select name="reminderType" id="reminderType" onchange="document.getElementById('rem-abs').style.display=this.value=='0'?'flex':'none';document.getElementById('rem-rel').style.display=this.value=='1'?'block':'none';">
                            <option value="0">@T["tasks.edit.reminderDateTime"]</option>
                            <option value="1">@T["tasks.edit.reminderBeforeDue"]</option>
                        </select>
                    </form-field>
                    <form-field label="@T["tasks.edit.reminderChannel"]">
                        <select name="channel">
                            <option value="3">@T["tasks.edit.channelEmailPush"]</option>
                            <option value="1">@T["tasks.edit.channelEmailOnly"]</option>
                            <option value="2">@T["tasks.edit.channelPushOnly"]</option>
                        </select>
                    </form-field>
                </div>
                <div class="field-row" id="rem-abs">
                    <form-field label="@T["tasks.edit.date"]"><input type="date" name="remindDate" /></form-field>
                    <form-field label="@T["tasks.edit.time"]"><input type="time" name="remindTime" /></form-field>
                </div>
                <div id="rem-rel" style="display:none">
                    <form-field label="@T["tasks.edit.minutesBeforeDue"]" hint="@T["tasks.edit.minutesBeforeDueHint"]">
                        <input type="number" name="offsetMinutes" value="60" min="0" />
                    </form-field>
                </div>
                <div class="form-buttons" style="margin-top:6px">
                    <button type="submit" class="btn btn-primary small"><icon name="bell" size="14" /> @T["tasks.edit.addReminder"]</button>
                </div>
            </form>
        </div>

        <!-- Teilen -->
        @if (Model.CanShare)
        {
            <div class="tab-panel" data-tab-panel="share">
                @if (Model.Shares.Count > 0)
                {
                    <div class="table-wrap mb">
                        <table class="table">
                            <thead><tr><th>@T["tasks.edit.shareUser"]</th><th>@T["tasks.edit.sharePermission"]</th><th></th></tr></thead>
                            <tbody>
                            @foreach (var s in Model.Shares)
                            {
                                <tr>
                                    <td>@s.SharedWithUser?.DisplayName</td>
                                    <td>@(s.Permission == Matdo.Web.Data.Entities.SharePermission.Edit ? T["tasks.edit.permissionEdit"] : T["tasks.edit.permissionView"])</td>
                                    <td class="actions-cell">
                                        <form method="post" asp-page-handler="Unshare" asp-route-id="@Model.Input.Id" style="display:inline">
                                            <input type="hidden" name="targetUserId" value="@s.SharedWithUserId" />
                                            <button type="submit" class="btn small danger"><icon name="x" size="14" /></button>
                                        </form>
                                    </td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                }
                @if (Model.ShareableUsers.Count == 0)
                {
                    <p class="muted">@T["tasks.edit.noShareableUsers"]</p>
                }
                else
                {
                    <form method="post" asp-page-handler="Share" asp-route-id="@Model.Input.Id">
                        <div class="field-row">
                            <form-field label="@T["tasks.edit.shareUser"]">
                                <select name="targetUserId">
                                    @foreach (var u in Model.ShareableUsers)
                                    {
                                        <option value="@u.Id">@u.DisplayName</option>
                                    }
                                </select>
                            </form-field>
                            <form-field label="@T["tasks.edit.sharePermission"]">
                                <select name="permission">
                                    <option value="1">@T["tasks.edit.permissionEdit"]</option>
                                    <option value="0">@T["tasks.edit.permissionView"]</option>
                                </select>
                            </form-field>
                        </div>
                        <div class="form-buttons" style="margin-top:6px">
                            <button type="submit" class="btn btn-primary small"><icon name="share" size="14" /> @T["tasks.edit.share"]</button>
                        </div>
                    </form>
                }
            </div>
        }
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
