@model Matdo.Web.Data.Entities.TaskItem
@inject Matdo.Web.Services.ICurrentUserAccessor Me
@{
    var t = Model;
    var meId = Me.UserId;
    var prioClass = t.Priority switch
    {
        TaskPriority.P1 => "p1",
        TaskPriority.P2 => "p2",
        TaskPriority.P3 => "p3",
        _ => ""
    };

    string? dueLabel = null;
    var overdue = false;
    if (t.DueDate.HasValue)
    {
        var due = t.DueDate.Value.ToLocalTime();
        var today = DateTime.Now.Date;
        overdue = due.Date < today && !t.IsCompleted;
        if (due.Date == today) dueLabel = "Heute";
        else if (due.Date == today.AddDays(1)) dueLabel = "Morgen";
        else if (due.Date == today.AddDays(-1)) dueLabel = "Gestern";
        else dueLabel = due.ToString("d. MMM");
        if (t.DueHasTime) dueLabel += " " + due.ToString("HH:mm");
    }
    var subCount = t.SubTasks?.Count ?? 0;
    var doneSub = t.SubTasks?.Count(s => s.IsCompleted) ?? 0;

    string? deadlineLabel = t.DeadlineDate.HasValue
        ? t.DeadlineDate.Value.ToLocalTime().ToString("d. MMM") + (t.DeadlineHasTime ? " " + t.DeadlineDate.Value.ToLocalTime().ToString("HH:mm") : "")
        : null;

    var prioNum = t.Priority switch { TaskPriority.P1 => 1, TaskPriority.P2 => 2, TaskPriority.P3 => 3, _ => 4 };
    string? prioText = prioNum switch { 1 => T["tasks.priority.p1"], 2 => T["tasks.priority.p2"], 3 => T["tasks.priority.p3"], _ => null };
    var reminderCount = t.Reminders?.Count ?? 0;

    // Inline-Bearbeiten: ?edit=<id> ersetzt diese Zeile durch den Composer im Bearbeiten-Modus.
    var _req = ViewContext.HttpContext.Request;
    long? _editId = long.TryParse(_req.Query["edit"], out var _eid) ? _eid : (long?)null;
    var _other = _req.Query.Where(kv => kv.Key != "edit").Select(kv => kv.Key + "=" + Uri.EscapeDataString(kv.Value.ToString()));
    var retUrl = _req.Path + (_other.Any() ? "?" + string.Join("&", _other) : "");
    var editUrl = retUrl + (retUrl.Contains('?') ? "&" : "?") + "edit=" + t.Id;
}
@if (_editId == t.Id)
{
    <partial name="_Composer" model="new Matdo.Web.ViewModels.ComposerOptions { EditTask = t, ReturnUrl = retUrl }" />
}
else
{
<div class="task-row @(t.IsCompleted ? "done" : "")">
    <div class="task-check @prioClass @(t.IsCompleted ? "checked" : "")"
         data-complete-task="@t.Id" data-completed="@(t.IsCompleted ? "true" : "false")"
         role="checkbox" aria-checked="@(t.IsCompleted ? "true" : "false")" title="@T["tasks.common.completed"]">
        @(t.IsCompleted ? "✓" : "")
    </div>
    <div class="task-body">
        <div class="task-title"><a href="/Tasks/Edit?id=@t.Id">@t.Title</a></div>
        @if (!string.IsNullOrWhiteSpace(t.Description))
        {
            <div class="task-desc">@t.Description</div>
        }
        <div class="task-meta">
            @* Alle Eigenschaften einheitlich als Badge (Pill). *@
            @if (dueLabel != null)
            {
                <span class="pill-label due @(overdue ? "overdue" : "")"><icon name="calendar" size="12" /> @dueLabel</span>
            }
            @if (prioText != null)
            {
                <span class="pill-label prio pri-@prioNum"><icon name="flag" size="12" /> @prioText</span>
            }
            @if (deadlineLabel != null)
            {
                <span class="pill-label"><icon name="flag" size="12" /> @T["tasks.edit.deadline"]: @deadlineLabel</span>
            }
            @if (reminderCount > 0)
            {
                <span class="pill-label"><icon name="bell" size="12" />@(reminderCount > 1 ? " " + reminderCount : "")</span>
            }
            @if (subCount > 0)
            {
                <span class="pill-label"><icon name="list" size="12" /> @doneSub/@subCount</span>
            }
            @if (t.Project != null)
            {
                <span class="pill-label"><span class="phash" style="color:@t.Project.Color">#</span>@t.Project.Name</span>
            }
            @if (t.Assignee != null)
            {
                <span class="pill-label" title="@T["tasks.row.assignedTo"]"><icon name="user" size="12" /> @t.Assignee.DisplayName</span>
            }
            @if (!string.IsNullOrEmpty(t.AnonymousAuthor))
            {
                <span class="pill-label" title="@T["projects.edit.anonTitle"]"><icon name="user" size="12" /> @T["tasks.row.anon"]: @t.AnonymousAuthor</span>
            }
            @if (t.TaskLabels != null)
            {
                @* Persönliche Labels: nur die eigenen Etiketten des Betrachters anzeigen. *@
                foreach (var tl in t.TaskLabels.Where(x => x.Label != null && x.Label!.OwnerId == meId))
                {
                    <span class="pill-label"><span class="tag-swatch" style="background:@tl.Label!.Color"></span> @tl.Label!.Name</span>
                }
            }
        </div>
    </div>
    <div class="task-actions">
        <a class="icon-btn sm" href="@editUrl" title="@T["common.edit"]" aria-label="@T["common.edit"]"><icon name="edit" size="15" /></a>
        <div class="tb-menu" data-menu>
            <button type="button" class="icon-btn sm" data-menu-toggle aria-label="@T["common.edit"]"><icon name="dots" size="16" /></button>
            <div class="menu-pop">
                <a class="menu-item" href="/Tasks/Edit?id=@t.Id"><icon name="edit" size="15" /> @T["common.edit"]</a>
                <button type="button" class="menu-item" data-task-duplicate="@t.Id"><icon name="copy" size="15" /> @T["tasks.row.duplicate"]</button>
                <div class="menu-sep"></div>
                <button type="button" class="menu-item danger" data-task-delete="@t.Id" data-confirm="@T["tasks.edit.deleteConfirm"]"><icon name="trash" size="15" /> @T["common.delete"]</button>
            </div>
        </div>
    </div>
</div>
}
