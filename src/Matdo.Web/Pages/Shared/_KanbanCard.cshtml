@model Matdo.Web.Data.Entities.TaskItem
@inject Matdo.Web.Services.ICurrentUserAccessor Me
@{
    var t = Model;
    var meId = Me.UserId;
    var prioClass = t.Priority switch { TaskPriority.P1 => "p1", TaskPriority.P2 => "p2", TaskPriority.P3 => "p3", _ => "" };
    var prioNum = t.Priority switch { TaskPriority.P1 => 1, TaskPriority.P2 => 2, TaskPriority.P3 => 3, _ => 4 };
    string? prioText = prioNum switch { 1 => T["tasks.priority.p1"], 2 => T["tasks.priority.p2"], 3 => T["tasks.priority.p3"], _ => null };
    var due = t.DueDate?.ToLocalTime();
    var overdue = due.HasValue && due.Value.Date < DateTime.Now.Date && !t.IsCompleted;
}
<div class="kanban-card" draggable="true" data-task-id="@t.Id">
    <div style="display:flex; gap:8px; align-items:flex-start">
        <div class="task-check @prioClass" data-complete-task="@t.Id" data-completed="false" title="@T["tasks.common.completed"]"></div>
        <div style="flex:1; min-width:0">
            <div class="task-title"><a href="/Tasks/Edit?id=@t.Id">@t.Title</a></div>
            <div class="task-meta">
                @if (due.HasValue)
                {
                    <span class="pill-label due @(overdue ? "overdue" : "")"><icon name="calendar" size="12" /> @due.Value.ToString("d. MMM")@(t.DueHasTime ? " " + due.Value.ToString("HH:mm") : "")</span>
                }
                @if (prioText != null)
                {
                    <span class="pill-label prio pri-@prioNum"><icon name="flag" size="12" /> @prioText</span>
                }
                @if (t.TaskLabels != null)
                {
                    foreach (var tl in t.TaskLabels.Where(x => x.Label != null && x.Label!.OwnerId == meId))
                    {
                        <span class="pill-label"><span class="tag-swatch" style="background:@tl.Label!.Color"></span> @tl.Label!.Name</span>
                    }
                }
            </div>
        </div>
    </div>
</div>
