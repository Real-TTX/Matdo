@page
@model Matdo.Web.Pages.Labels.LabelsIndexModel
@{
    ViewData["Title"] = T["labels.index.title"];
}
<div class="page-head"><h1>@T["labels.index.title"]</h1></div>

<list-view id="labels">
    <list-toolbar>
        <form method="get" class="search">
            <input type="search" name="q" value="@Model.Search" placeholder="@T["labels.index.searchPlaceholder"]" />
        </form>
    </list-toolbar>

    <list-table>
        <thead>
            <tr><th>@T["labels.index.label"]</th><th>@T["common.color"]</th><th>@T["common.favorite"]</th><th></th></tr>
        </thead>
        <tbody>
        @foreach (var l in Model.Items)
        {
            <tr>
                <td><a class="row-link" href="/Labels/View?id=@l.Id"><span class="tag-swatch" style="background:@l.Color; margin-right:6px"></span>@l.Name</a></td>
                <td><code>@l.Color</code></td>
                <td>@(l.IsFavorite ? "★" : "")</td>
                <td class="actions-cell">
                    <a class="btn small" href="/Labels/Edit?id=@l.Id"><icon name="edit" size="14" /> @T["common.edit"]</a>
                </td>
            </tr>
        }
        @if (Model.Items.Count == 0)
        {
            <tr><td colspan="4"><div class="empty">@T["labels.index.empty"]</div></td></tr>
        }
        </tbody>
    </list-table>

    <list-actions>
        <a class="btn btn-primary" href="/Labels/Edit"><icon name="plus" size="16" /> @T["labels.index.newLabel"]</a>
    </list-actions>
</list-view>
