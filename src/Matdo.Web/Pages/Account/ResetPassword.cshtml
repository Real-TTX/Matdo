@page
@model Matdo.Web.Pages.Account.ResetPasswordModel
@{
    ViewData["Title"] = T["auth.resetTitle"];
}
<div class="auth-wrap">
    <div class="auth-card">
        <div class="logo"><icon name="check" size="26" /> Matdo</div>
        <h1>@T["auth.resetTitle"]</h1>

        @if (Model.Done)
        {
            <div class="alert success">@T["auth.resetDone"]</div>
            <div class="auth-alt"><a href="/Account/Login">@T["auth.backToLogin"]</a></div>
        }
        else if (Model.Error == "invalid")
        {
            <div class="alert error">@T["auth.resetInvalid"]</div>
            <div class="auth-alt"><a href="/Account/ForgotPassword">@T["auth.forgotTitle"]</a></div>
        }
        else
        {
            <p class="sub">@T["auth.resetSubtitle"]</p>
            @if (!string.IsNullOrEmpty(Model.Error))
            {
                <div class="alert error">@Model.Error</div>
            }
            <form method="post">
                <input type="hidden" asp-for="Input.Token" />
                <div asp-validation-summary="ModelOnly" class="validation-summary"></div>
                <form-field label="@T["auth.newPassword"]" for="Input_Password" required="true">
                    <input asp-for="Input.Password" type="password" autocomplete="new-password" placeholder="••••••••" autofocus />
                    <span asp-validation-for="Input.Password" class="field-error"></span>
                </form-field>
                <form-field label="@T["auth.confirmPassword"]" for="Input_PasswordConfirm" required="true">
                    <input asp-for="Input.PasswordConfirm" type="password" autocomplete="new-password" placeholder="••••••••" />
                    <span asp-validation-for="Input.PasswordConfirm" class="field-error"></span>
                </form-field>
                <button type="submit" class="btn btn-primary">@T["auth.resetSubmit"]</button>
            </form>
        }
    </div>
</div>
