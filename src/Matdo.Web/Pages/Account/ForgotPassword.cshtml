@page
@model Matdo.Web.Pages.Account.ForgotPasswordModel
@{
    ViewData["Title"] = T["auth.forgotTitle"];
}
<div class="auth-wrap">
    <div class="auth-card">
        <div class="logo"><icon name="check" size="26" /> Matdo</div>
        <h1>@T["auth.forgotTitle"]</h1>
        <p class="sub">@T["auth.forgotSubtitle"]</p>

        @if (Model.Sent)
        {
            <div class="alert info">@T["auth.forgotSent"]</div>
            <div class="auth-alt"><a href="/Account/Login">@T["auth.backToLogin"]</a></div>
        }
        else
        {
            <form method="post">
                <div asp-validation-summary="ModelOnly" class="validation-summary"></div>
                <form-field label="@T["common.email"]" for="Input_Email" required="true">
                    <input asp-for="Input.Email" type="email" autocomplete="username" placeholder="du@beispiel.de" autofocus />
                    <span asp-validation-for="Input.Email" class="field-error"></span>
                </form-field>
                <button type="submit" class="btn btn-primary">@T["auth.forgotSubmit"]</button>
            </form>
            <div class="auth-alt"><a href="/Account/Login">@T["auth.backToLogin"]</a></div>
        }
    </div>
</div>
