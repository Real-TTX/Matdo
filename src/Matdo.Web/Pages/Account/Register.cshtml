@page
@model Matdo.Web.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Registrieren";
}
<div class="auth-wrap">
    <div class="auth-card">
        <div class="logo"><icon name="check" size="26" /> Matdo</div>
        <h1>Konto erstellen</h1>
        <p class="sub">Leg los mit deinen Aufgaben.</p>

        @if (!string.IsNullOrEmpty(Model.Error))
        {
            <div class="alert error">@Model.Error</div>
        }

        <form method="post">
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <form-field label="Name" for="Input_DisplayName" required="true">
                <input asp-for="Input.DisplayName" placeholder="Max Mustermann" autofocus />
                <span asp-validation-for="Input.DisplayName" class="field-error"></span>
            </form-field>

            <form-field label="E-Mail" for="Input_Email" required="true">
                <input asp-for="Input.Email" type="email" autocomplete="username" placeholder="du@beispiel.de" />
                <span asp-validation-for="Input.Email" class="field-error"></span>
            </form-field>

            <form-field label="Passwort" for="Input_Password" required="true">
                <input asp-for="Input.Password" type="password" autocomplete="new-password" placeholder="Mindestens 6 Zeichen" />
                <span asp-validation-for="Input.Password" class="field-error"></span>
            </form-field>

            <form-field label="Passwort bestätigen" for="Input_PasswordConfirm" required="true">
                <input asp-for="Input.PasswordConfirm" type="password" autocomplete="new-password" placeholder="••••••••" />
                <span asp-validation-for="Input.PasswordConfirm" class="field-error"></span>
            </form-field>

            <button type="submit" class="btn btn-primary">Konto erstellen</button>
        </form>

        <div class="auth-alt">Bereits registriert? <a href="/Account/Login">Anmelden</a></div>
    </div>
</div>
