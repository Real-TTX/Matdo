@page
@model Matdo.Web.Pages.Account.LoginModel
@inject Matdo.Web.Services.JsonConfigService AppCfg
@{
    ViewData["Title"] = T["auth.login"];
}
<div class="auth-wrap">
    <div class="auth-card">
        <div class="logo"><icon name="check" size="26" /> Matdo</div>
        <h1>@T["auth.welcomeBack"]</h1>
        <p class="sub">@T["auth.loginSubtitle"]</p>

        @if (!string.IsNullOrEmpty(Model.Error))
        {
            <div class="alert error">@Model.Error</div>
        }

        <form method="post">
            <input type="hidden" asp-for="ReturnUrl" value="@Model.ReturnUrl" />
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <form-field label="@T["common.email"]" for="Input_Email" required="true">
                <input asp-for="Input.Email" type="email" autocomplete="username" placeholder="du@beispiel.de" autofocus />
                <span asp-validation-for="Input.Email" class="field-error"></span>
            </form-field>

            <form-field label="@T["auth.password"]" for="Input_Password" required="true">
                <input asp-for="Input.Password" type="password" autocomplete="current-password" placeholder="••••••••" />
                <span asp-validation-for="Input.Password" class="field-error"></span>
            </form-field>

            <button type="submit" class="btn btn-primary">@T["auth.login"]</button>
        </form>

        <div class="auth-alt"><a href="/Account/ForgotPassword">@T["auth.forgotLink"]</a></div>

        @if (AppCfg.Current.AllowRegistration)
        {
            <div class="auth-alt">@T["auth.noAccount"] <a href="/Account/Register">@T["auth.register"]</a></div>
        }
    </div>
</div>
